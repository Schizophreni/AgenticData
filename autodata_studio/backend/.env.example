# Provider keys (referenced by RoleBinding.api_key_env)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=

# Local vLLM/SGLang endpoints are configured per-role in the UI via base_url, e.g.
#   provider=openai_compat, base_url=http://localhost:8001/v1, model=Qwen3.5-VL-7B

# Grounding source (colon-separated image dirs for the Zhihu adapter)
ZHIHU_IMG_DIRS=/inspire/qb-ilm2/project/video-understanding/public/lance_hub/Zhihu/download/img:/inspire/qb-ilm2/project/video-understanding/public/lance_hub/Zhihu/download/img2:/inspire/qb-ilm2/project/video-understanding/public/datasets/iconQA/iconqa_data/iconqa

AUTODATA_MAX_INFLIGHT=4
AUTODATA_STEP_BUDGET=15
